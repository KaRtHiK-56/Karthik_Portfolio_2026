rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - username: string (required, 3-20 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: scores
    // Document ID: {scoreId} (auto-generated)
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - score: number (required, positive)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'username', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.username is string &&
             data.username.size() >= 3 &&
             data.username.size() <= 20 &&
             data.createdAt is timestamp;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'username', 'score', 'timestamp']) &&
             data.keys().hasOnly(['uid', 'username', 'score', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.score is number &&
             data.score >= 0 &&
             data.score <= 1000000 &&
             data.username is string &&
             data.username.size() <= 20 &&
             data.timestamp is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
    }

    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow delete, update: if false;
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidScore(request.resource.data);
      allow delete: if false;
    }
  }
}
